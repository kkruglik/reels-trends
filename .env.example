APIFY_TOKEN=
DATABASE_URL=sqlite+aiosqlite:////app/data/reels_trends.db
TELEGRAM_BOT_TOKEN=

# Worker / HTTP
HTTPX_TIMEOUT=200.0
NUM_WORKERS=4

# Scheduler cadence
SCRAPE_POSTS_INTERVAL_HOURS=2
CHECK_TRENDS_CRON_MINUTE=15
SCRAPE_PROFILE_CRON_HOUR=3
DAILY_SUMMARY_CRON_HOUR=20
DAILY_SUMMARY_TIMEZONE=Europe/Tallinn

# Apify scraping
SCRAPE_RESULTS_LIMIT=30
SCRAPE_LOOKBACK_DAYS=2

# Trend detection
TRENDING_FRESHNESS_HOURS=6
TRENDING_HISTORY_LIMIT=500
TRENDING_MULTIPLIER=1.5
TRENDING_BASELINE_QUANTILE=0.75

# Daily summary
SUMMARY_LOOKBACK_DAYS=1
SUMMARY_TOP_COUNT=5

# Access control (empty = allow all)
TELEGRAM_ALLOWED_USERS=[]
